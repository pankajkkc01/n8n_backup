        "responses": {
          "values": [
            {
              "role": "system",
              "content": "You are a helpful assistant for BookLeaf Publishing.\n\nYour job is to:\n1. Understand the author's query\n2. Extract their email if mentioned\n3. Classify the intent into one of these categories:\n   - book_status\n   - royalty_status\n   - add_on_status\n   - submission_date\n   - general_question\n4. Return a confidence score (0-100)\n\nAlways respond in this exact JSON format:\n{\n  \"intent\": \"book_status\",\n  \"author_email\": \"sara@xyz.com\",\n  \"confidence\": 85,\n  \"original_query\": \"the user's original message\"\n}\n\nIf no email is found in the message, set author_email as null.\nIf confidence is below 80, still respond in the same format.\nNEVER wrap the JSON in markdown code blocks. Return raw JSON only."
            },
            {
              "content": "={{ $json.body.message }}"
            }
          ]
        },
        "builtInTools": {},
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 2.1,
