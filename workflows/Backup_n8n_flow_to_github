    {
      "parameters": {
        "jsCode": "// Runs once for ALL items — matches Prepare Payload items with SHA items by index\nconst preparedItems = $('Prepare Payload').all();\nconst shaItems = $('Get File SHA from GitHub').all();\n\nconst results = [];\n\nfor (let i = 0; i < preparedItems.length; i++) {\n  const prepared = preparedItems[i].json;\n  const shaResponse = shaItems[i] ? shaItems[i].json : {};\n  const sha = shaResponse.sha || null; // null if file doesn't exist yet (404)\n\n  const body = {\n    message: `Backup: ${prepared.workflowName}`,\n    content: prepared.content,\n    branch: 'main'\n  };\n\n  // Only add SHA if file already exists — GitHub requires it for updates\n  if (sha) {\n    body.sha = sha;\n  }\n\n  results.push({\n    json: {\n      fileName: prepared.fileName,\n      workflowName: prepared.workflowName,\n      body\n    }\n  });\n}\n\nreturn results;"
      },
