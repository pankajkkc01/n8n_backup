    {
      "parameters": {
        "jsCode": "// Runs once for ALL items — builds array of {fileName, workflowName, content}\nconst workflowItems = $('Get Workflow Details').all();\nconst results = [];\n\nfor (let i = 0; i < workflowItems.length; i++) {\n  const wf = workflowItems[i].json;\n\n  const safeName = wf.name\n    .replace(/[\\/\\\\:*?\"<>|]/g, '-')\n    .replace(/\\s+/g, '_')\n    .trim();\n\n  const fileName = `${safeName}.json`;\n  const content = Buffer.from(JSON.stringify(wf, null, 2)).toString('base64');\n\n  results.push({\n    json: { fileName, workflowName: wf.name, workflowId: wf.id, content }\n  });\n}\n\nreturn results;"
      },
